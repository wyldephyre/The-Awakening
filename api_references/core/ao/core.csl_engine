    Panel_Desc :: struct {
        axis:             Axis;
        width:            Size;
        height:           Size;
        cross_align:      Cross_Align;
        main_align:       Main_Align;
        background:       Panel_Background_Kind;
        gap:              float;
        padding:          v4;
        tint:             v4;
        min_width:        float;
        max_width:        float;
        min_height:       float;
        max_height:       float;
        clip_children:    bool;
        grid_columns:     s64;
        progress_t:       float;
        progress_bar_style: Progress_Bar_Style;
        progress_bar_fill_tint: v4;
        show_background:  bool;
        mask_scope:       bool;
        opacity:          float;
    }

    Text_Desc :: struct {
        role:              Text_Role;
        override_flags:    s64;
        halign:            Text_Settings.Horizontal_Alignment;
        valign:            Text_Settings.Vertical_Alignment;
        size_multiplier:   float;
        word_wrap:         bool;
        color:             v4;
    }

    Widget_Desc :: struct {
        panel:         Panel_Desc;
        label_text:    Text_Desc;
        disabled:      bool;
        toggle_visual: Toggle_Visual_Kind;
    }

    Interact_Handle :: struct {
        slot:       s64;
        generation: u64;
    }

    pixels :: proc(px: float) -> Size {
        result: Size;
        result.kind = .PIXELS;
        result.value = px;
        return result;
    }

    flex :: proc(weight := 1.0) -> Size {
        result: Size;
        result.kind = .FLEX;
        result.value = weight;
        return result;
    }

    flex_fit :: proc(weight := 1.0) -> Size {
        result: Size;
        result.kind = .FLEX_FIT;
        result.value = weight;
        return result;
    }

    fit :: proc() -> Size {
        result: Size;
        result.kind = .FIT;
        result.value = 0;
        return result;
    }

    modal_theme_to_background :: proc(theme: Modal_Theme) -> Panel_Background_Kind {
        switch theme {
            case .BLACK:         return .MODAL_BLACK;
            case .BLUE:          return .MODAL_BLUE;
            case .BROWN:         return .MODAL_BROWN;
            case .GOLD:          return .MODAL_GOLD;
            case .GREEN:         return .MODAL_GREEN;
            case .GREY:          return .MODAL_GREY;
            case .ORANGE:        return .MODAL_ORANGE;
            case .PURPLE:        return .MODAL_PURPLE;
            case .RED:           return .MODAL_RED;
            case .WHITE:         return .MODAL_WHITE;
            case .YELLOW:        return .MODAL_YELLOW;
            case .TRANSP_BLACK:  return .MODAL_TRANSP_BLACK;

            case .BLACK_WITH_FOOTER: return .MODAL_WITH_FOOTER_BLACK;
            case .BLUE_WITH_FOOTER: return .MODAL_WITH_FOOTER_BLUE;
            case .BROWN_WITH_FOOTER: return .MODAL_WITH_FOOTER_BROWN;
            case .GOLD_WITH_FOOTER: return .MODAL_WITH_FOOTER_GOLD;
            case .GREEN_WITH_FOOTER: return .MODAL_WITH_FOOTER_GREEN;
            case .GREY_WITH_FOOTER: return .MODAL_WITH_FOOTER_GREY;
            case .ORANGE_WITH_FOOTER: return .MODAL_WITH_FOOTER_ORANGE;
            case .PURPLE_WITH_FOOTER: return .MODAL_WITH_FOOTER_PURPLE;
            case .RED_WITH_FOOTER: return .MODAL_WITH_FOOTER_RED;
            case .WHITE_WITH_FOOTER: return .MODAL_WITH_FOOTER_WHITE;
            case .YELLOW_WITH_FOOTER: return .MODAL_WITH_FOOTER_YELLOW;
        }
        return .BACKGROUND_NONE;
    }

    interior_kind_to_background :: proc(kind: Interior_Kind) -> Panel_Background_Kind {
        switch kind {
            case .INSET: return .INTERIOR_INSET;
            case .WHITE: return .INTERIOR_WHITE;
        }
        return .BACKGROUND_NONE;
    }

    text_set_halign :: proc(d: *Text_Desc, align: Text_Settings.Horizontal_Alignment) {
        d.override_flags = d.override_flags | Text_Override_HALIGN;
        d.halign = align;
    }

    text_set_valign :: proc(d: *Text_Desc, align: Text_Settings.Vertical_Alignment) {
        d.override_flags = d.override_flags | Text_Override_VALIGN;
        d.valign = align;
    }

    text_set_size_mult :: proc(d: *Text_Desc, mult: float) {
        d.override_flags = d.override_flags | Text_Override_SIZE_MULT;
        d.size_multiplier = mult;
    }

    text_set_color :: proc(d: *Text_Desc, color: v4) {
        d.override_flags = d.override_flags | Text_Override_COLOR;
        d.color = color;
    }

    text_set_word_wrap :: proc(d: *Text_Desc, wrap: bool) {
        d.override_flags = d.override_flags | Text_Override_WORD_WRAP;
        d.word_wrap = wrap;
    }

    /// Vertical flex-fill column layout, no background.
    layout_column :: proc() -> Panel_Desc {
        desc: Panel_Desc;
        desc.axis = .VERTICAL;
        desc.width = flex(1);
        desc.height = flex(1);
        desc.cross_align = .STRETCH;
        desc.main_align = .START;
        desc.background = .BACKGROUND_NONE;
        desc.gap = 0;
        desc.padding = .{0, 0, 0, 0};
        desc.tint = .{1, 1, 1, 0};
        desc.min_width = 0;
        desc.max_width = 0;
        desc.min_height = 0;
        desc.max_height = 0;
        desc.clip_children = false;
        desc.grid_columns = 0;
        desc.progress_t = 0;
        desc.progress_bar_style = .PROGRESS_BAR_NONE;
        desc.progress_bar_fill_tint = .{1, 1, 1, 1};
        desc.show_background = true;
        desc.mask_scope = false;
        desc.opacity = 1.0;
        return desc;
    }

    /// Horizontal flex-fill row layout, no background.
    layout_row :: proc() -> Panel_Desc {
        desc: Panel_Desc;
        desc.axis = .HORIZONTAL;
        desc.width = flex(1);
        desc.height = flex(1);
        desc.cross_align = .STRETCH;
        desc.main_align = .START;
        desc.background = .BACKGROUND_NONE;
        desc.gap = 0;
        desc.padding = .{0, 0, 0, 0};
        desc.tint = .{1, 1, 1, 0};
        desc.min_width = 0;
        desc.max_width = 0;
        desc.min_height = 0;
        desc.max_height = 0;
        desc.clip_children = false;
        desc.grid_columns = 0;
        desc.progress_t = 0;
        desc.progress_bar_style = .PROGRESS_BAR_NONE;
        desc.progress_bar_fill_tint = .{1, 1, 1, 1};
        desc.show_background = true;
        desc.mask_scope = false;
        desc.opacity = 1.0;
        return desc;
    }

    /// Horizontal row with explicit sizing and gap, no background.
    layout_row :: proc(width: Size, height: Size, gap: float) -> Panel_Desc {
        desc := layout_row();
        desc.width = width;
        desc.height = height;
        desc.gap = gap;
        return desc;
    }

    layout_centered :: proc(width: Size, height: Size) -> Panel_Desc {
        desc := layout_column();
        desc.width = width;
        desc.height = height;
        desc.cross_align = .CENTER;
        desc.main_align = .CENTER;
        desc.show_background = false;
        return desc;
    }

    /// Vertical flex-fill column with a background style.
    panel_styled :: proc(bg: Panel_Background_Kind) -> Panel_Desc {
        desc := layout_column();
        desc.background = bg;
        return desc;
    }

    /// Modal-themed panel (vertical flex-fill).
    panel_modal :: proc(theme: Modal_Theme) -> Panel_Desc {
        return panel_styled(modal_theme_to_background(theme));
    }

    panel_modal :: proc(theme: Modal_Theme, gap: float) -> Panel_Desc {
        desc := panel_modal(theme);
        desc.gap = gap;
        return desc;
    }

    panel_modal :: proc(theme: Modal_Theme, gap: float, padding: v4) -> Panel_Desc {
        desc := panel_modal(theme);
        desc.gap = gap;
        desc.padding = padding;
        return desc;
    }

    panel_modal :: proc(theme: Modal_Theme, width: Size, height: Size) -> Panel_Desc {
        desc := panel_modal(theme);
        desc.width = width;
        desc.height = height;
        return desc;
    }

    panel_modal :: proc(theme: Modal_Theme, width: Size, height: Size, gap: float) -> Panel_Desc {
        desc := panel_modal(theme);
        desc.width = width;
        desc.height = height;
        desc.gap = gap;
        return desc;
    }

    panel_modal :: proc(theme: Modal_Theme, width: Size, height: Size, gap: float, padding: v4) -> Panel_Desc {
        desc := panel_modal(theme);
        desc.width = width;
        desc.height = height;
        desc.gap = gap;
        desc.padding = padding;
        return desc;
    }

    panel_modal :: proc(theme: Modal_Theme, cross_align: Cross_Align) -> Panel_Desc {
        desc := panel_modal(theme);
        desc.cross_align = cross_align;
        return desc;
    }

    panel_modal :: proc(theme: Modal_Theme, main_align: Main_Align) -> Panel_Desc {
        desc := panel_modal(theme);
        desc.main_align = main_align;
        return desc;
    }

    panel_modal :: proc(theme: Modal_Theme, clip_children: bool) -> Panel_Desc {
        desc := panel_modal(theme);
        desc.clip_children = clip_children;
        return desc;
    }

    /// r-themed panel (vertical flex-fill).
    panel_interior :: proc(kind: Interior_Kind) -> Panel_Desc {
        desc := panel_styled(interior_kind_to_background(kind));
        desc.mask_scope = true;
        return desc;
    }

    panel_interior_fill :: proc(kind: Interior_Kind) -> Panel_Desc {
        desc := panel_interior(kind);
        desc.width = flex(1);
        desc.height = flex(1);
        return desc;
    }

    /// Modal-themed header with fixed pixel height.
    panel_header :: proc(theme: Modal_Theme, height_px: float) -> Panel_Desc {
        return panel_modal(theme, flex(), pixels(height_px));
    }

    /// Kit progress bar panel.
    panel_progress_bar :: proc(style: Progress_Bar_Style, progress_t: float, fill_tint: v4 = {1, 1, 1, 1}, width: Size = .{.FLEX, 1.0}, height: Size = .{.FIT, 1.0}) -> Panel_Desc {
        desc: Panel_Desc;
        desc.axis = .VERTICAL;
        desc.width = width;
        desc.height = height;
        desc.cross_align = .STRETCH;
        desc.main_align = .START;
        desc.background = .BACKGROUND_NONE;
        desc.gap = 0;
        desc.padding = .{0, 0, 0, 0};
        desc.tint = .{1, 1, 1, 0};
        desc.min_width = 0;
        desc.max_width = 0;
        desc.min_height = 0;
        desc.max_height = 0;
        desc.clip_children = false;
        desc.grid_columns = 0;
        desc.progress_t = progress_t;
        desc.progress_bar_style = style;
        desc.progress_bar_fill_tint = fill_tint;
        desc.show_background = true;
        desc.mask_scope = false;
        desc.opacity = 1.0;
        return desc;
    }

    text_title :: proc() -> Text_Desc {
        d: Text_Desc;
        d.role = .TITLE;
        return d;
    }

    text_body :: proc() -> Text_Desc {
        d: Text_Desc;
        d.role = .BODY;
        return d;
    }

    text_button :: proc() -> Text_Desc {
        d: Text_Desc;
        d.role = .BUTTON;
        return d;
    }

    text_button_auto :: proc() -> Text_Desc {
        d: Text_Desc;
        d.role = .BUTTON_AUTO;
        return d;
    }

    widget_desc_button_default :: proc(bg: Panel_Background_Kind = .BUTTON_BASIC_YELLOW1) -> Widget_Desc {
        w: Widget_Desc;
        w.panel.axis = .VERTICAL;
        w.panel.width = fit();
        w.panel.height = fit();
        w.panel.cross_align = .CENTER;
        w.panel.main_align = .CENTER;
        w.panel.background = bg;
        w.panel.gap = 4;
        w.panel.padding = v4{10, 20, 10, 20};
        w.panel.tint = v4{1, 1, 1, 1};
        w.panel.min_width = 0;
        w.panel.max_width = 0;
        w.panel.min_height = 0;
        w.panel.max_height = 0;
        w.panel.clip_children = false;
        w.panel.grid_columns = 0;
        w.panel.progress_t = 0;
        w.panel.progress_bar_style = .PROGRESS_BAR_NONE;
        w.panel.progress_bar_fill_tint = v4{1, 1, 1, 1};
        w.panel.show_background = true;
        w.panel.mask_scope = false;
        w.panel.opacity = 1.0;
        w.label_text.role = .BUTTON;
        w.disabled = false;
        w.toggle_visual = .TOGGLE_VISUAL_DEFAULT;
        return w;
    }

    widget_desc_button_auto_default :: proc(bg: Panel_Background_Kind = .BUTTON_BASIC_YELLOW1) -> Widget_Desc {
        w := widget_desc_button_default(bg);
        w.label_text.role = .BUTTON_AUTO;
        return w;
    }

    Begin_Desc :: struct {
        rect:           Rect  #offset 0;
        layer:          s64   #offset 16;
        backdrop:       bool  #offset 24;
        backdrop_color: v4    #offset 28;
        blocks_input:   bool  #offset 44;
    } #foreign_struct "UIK::Begin_Desc" #size 48

    window :: proc(rect: Rect) -> Begin_Desc {
        desc: Begin_Desc;
        desc.rect = rect;
        desc.layer = 0;
        desc.backdrop = false;
        desc.backdrop_color = .{0, 0, 0, 0.5};
        desc.blocks_input = false;
        return desc;
    }

    modal :: proc(rect: Rect, layer: s64) -> Begin_Desc {
        desc: Begin_Desc;
        desc.rect = rect;
        desc.layer = layer;
        desc.backdrop = true;
        desc.backdrop_color = .{0, 0, 0, 0.5};
        desc.blocks_input = true;
        return desc;
    }

    modal :: proc(rect: Rect, layer: s64, backdrop_color: v4) -> Begin_Desc {
        desc: Begin_Desc;
        desc.rect = rect;
        desc.layer = layer;
        desc.backdrop = true;
        desc.backdrop_color = backdrop_color;
        desc.blocks_input = true;
        return desc;
    }

    begin :: proc(rect: Rect) #foreign "uik_begin";
    begin :: proc(desc: Begin_Desc) #foreign "uik_begin_desc";
    end :: proc() #foreign "uik_end";
    
    panel_begin :: proc(desc: Panel_Desc) #foreign "uik_panel_begin";
    panel_begin_interactive :: proc(id: string, desc: Panel_Desc, disabled: bool = false) -> Interact_Handle #foreign "uik_panel_begin_interactive";
    resolve_parent_tint :: proc() -> v4 #foreign "uik_resolve_parent_tint";
    panel_end :: proc() #foreign "uik_panel_end";
    text :: proc(text: string, desc: Text_Desc) #foreign "uik_text";
    toggle :: proc(id: string, label: string, value: *bool, desc: Widget_Desc) -> Interact_Handle #foreign "uik_toggle";
    image :: proc(texture: Texture_Asset, tint: v4 = {1, 1, 1, 1}) #foreign "uik_image";
    image_nine :: proc(texture: Texture_Asset, nine_slice: Texture_Nine_Slice_Data, tint: v4 = {1, 1, 1, 1}) #foreign "uik_image_nine";
    spacer :: proc(width: Size, height: Size) #foreign "uik_spacer";
    progress_bar :: proc(track_desc: Panel_Desc) #foreign "uik_progress_bar";
    scroll_area_begin :: proc(id: string, viewport_desc: Panel_Desc, scroll_flags: s64 = 139264) #foreign "uik_scroll_area_begin";
    scroll_area_end :: proc() #foreign "uik_scroll_area_end";
    grid_begin :: proc(columns: s64, cell_height: float) #foreign "uik_grid_begin";
    grid_end :: proc() #foreign "uik_grid_end";

    card_begin :: proc(id: string, desc: Card_Desc, before_draw: u64 = 0, after_draw: u64 = 0, userdata: u64 = 0) #foreign "uik_card_begin";
    card_end :: proc() -> Interact_Handle #foreign "uik_card_end";
    card_zone :: proc(zone: Card_Zone) #foreign "uik_card_zone";
    card_zone_end :: proc() #foreign "uik_card_zone_end";
    card_push_unmask :: proc() #foreign "uik_card_push_unmask";
    card_pop_unmask :: proc() #foreign "uik_card_pop_unmask";
    card_badge :: proc(zone: Card_Zone, texture: Texture_Asset) #foreign "uik_card_badge";
    card_badge_text :: proc(zone: Card_Zone, text: string, desc: Text_Desc) #foreign "uik_card_badge_text";

    card_desc :: proc(width: Size, height: Size, tint: v4, orientation: Card_Orientation, media_fraction: float, header_fraction: float, footer_fraction: float) -> Card_Desc {
        desc: Card_Desc;
        desc.width = width;
        desc.height = height;
        desc.tint = tint;
        desc.orientation = orientation;
        desc.media_fraction = media_fraction;
        desc.header_fraction = header_fraction;
        desc.footer_fraction = footer_fraction;
        desc.disabled = false;
        return desc;
    }

    card_portrait :: proc(width: Size, height: Size, tint: v4) -> Card_Desc {
        return card_desc(width, height, tint, .PORTRAIT, 1.0, 0.15, 0.20);
    }

    card_landscape :: proc(width: Size, height: Size, tint: v4) -> Card_Desc {
        return card_desc(width, height, tint, .LANDSCAPE, 0.35, 0.0, 0.0);
    }

    divider_impl :: proc(thickness: float, color: v4) #foreign "uik_divider";
    divider :: proc(thickness: float = 1.0, color: v4 = {1, 1, 1, 0.2}) {
        divider_impl(thickness, color);
    }
    image_fitted :: proc(texture: Texture_Asset, desc: Image_Desc, tint: v4 = {1, 1, 1, 1}) #foreign "uik_image_fitted";
    overlay_begin :: proc(anchor: Overlay_Anchor, offset: v2 = {0, 0}) #foreign "uik_overlay_begin";
    overlay_begin :: proc(anchor: Overlay_Anchor, desc: Panel_Desc, offset: v2 = {0, 0}) #foreign "uik_overlay_begin_desc";
    overlay_begin :: proc(anchor: Overlay_Anchor, desc: Panel_Desc, offset: v2, align_x: Content_Align, align_y: Content_Align) #foreign "uik_overlay_begin_aligned";
    overlay_end :: proc() #foreign "uik_overlay_end";
    tab_bar_begin :: proc(id: string, active_index: *s64, active_style: Panel_Background_Kind = .BUTTON_TAB_MED_YELLOW, inactive_style: Panel_Background_Kind = .BUTTON_TAB_MED_GREY) #foreign "uik_tab_bar_begin";
    tab_bar_begin_desc :: proc(id: string, active_index: *s64, desc: Panel_Desc, active_style: Panel_Background_Kind = .BUTTON_TAB_MED_YELLOW, inactive_style: Panel_Background_Kind = .BUTTON_TAB_MED_GREY) #foreign "uik_tab_bar_begin_desc";
    tab :: proc(label: string, index: s64) -> Interact_Handle #foreign "uik_tab";
    tab :: proc(label: string, index: s64, desc: Widget_Desc) -> Interact_Handle #foreign "uik_tab_desc";
    tab_bar_end :: proc() #foreign "uik_tab_bar_end";
    currency :: proc(icon: Texture_Asset, amount: s64, desc: Text_Desc) #foreign "uik_currency";

    title_desc :: proc(style: Title_Banner_Style, tint: v4) -> Title_Desc {
        desc: Title_Desc;
        desc.style = style;
        desc.tint = tint;
        desc.text_desc = text_title();
        return desc;
    }

    title_area_desc :: proc(title: string, style: Title_Area_Style = .SIMPLE, show_exit: bool = true) -> Title_Area_Desc {
        desc: Title_Area_Desc;
        desc.title = title;
        desc.style = style;
        desc.show_exit = show_exit;
        desc.tint = v4{0, 0, 0, 0};
        return desc;
    }

    image_desc :: proc(fit: Image_Fit = .CONTAIN) -> Image_Desc {
        desc: Image_Desc;
        desc.fit = fit;
        desc.align_x = .CENTER;
        desc.align_y = .CENTER;
        desc.offset = .{0, 0};
        return desc;
    }

    resolve :: proc(handle: Interact_Handle) -> Interact_Result #foreign "uik_resolve";

    // ── Interaction query helpers (reimplemented in CSL) ──

    clicked :: proc(handle: Interact_Handle) -> bool { return resolve(handle).clicked; }
    hovering :: proc(handle: Interact_Handle) -> bool { return resolve(handle).hovering; }
    pressed :: proc(handle: Interact_Handle) -> bool { return resolve(handle).pressed; }
    released :: proc(handle: Interact_Handle) -> bool { return resolve(handle).released; }
    just_pressed :: proc(handle: Interact_Handle) -> bool { return resolve(handle).just_pressed; }
    active :: proc(handle: Interact_Handle) -> bool { return resolve(handle).active; }
    double_clicked :: proc(handle: Interact_Handle) -> bool { return resolve(handle).double_clicked; }

    // ── Composite widgets (reimplemented in CSL) ──

    button :: proc(id: string, label: string, desc: Widget_Desc) -> Interact_Handle {
        handle := panel_begin_interactive(id, desc.panel, desc.disabled);
        text(label, desc.label_text);
        panel_end();
        return handle;
    }

    icon_button :: proc(id: string, icon: Texture_Asset, desc: Widget_Desc) -> Interact_Handle {
        handle := panel_begin_interactive(id, desc.panel, desc.disabled);
        if icon != null { image_fitted(icon, image_desc(.CONTAIN)); }
        panel_end();
        return handle;
    }

    icon_button_label :: proc(id: string, icon: Texture_Asset, label: string, desc: Widget_Desc) -> Interact_Handle {
        d := desc;
        d.panel.axis = .HORIZONTAL;
        d.panel.cross_align = .CENTER;
        if d.panel.gap <= 0 { d.panel.gap = 8; }
        handle := panel_begin_interactive(id, d.panel, d.disabled);
        if icon != null { image_fitted(icon, image_desc(.CONTAIN)); }
        text(label, d.label_text);
        panel_end();
        return handle;
    }

    title :: proc(label: string, icon: Texture_Asset, desc: Title_Desc) {
        bg : Panel_Background_Kind = .BANNER_NORMAL;
        if desc.style == .FANCY { bg = .BANNER_FANCY; }
        panel := panel_styled(bg);
        panel.axis = .HORIZONTAL;
        panel.width = flex(1);
        panel.height = fit();
        panel.cross_align = .CENTER;
        panel.main_align = .CENTER;
        panel.tint = desc.tint;
        panel.padding = v4{12, 20, 12, 20};
        panel.gap = 8;
        panel_begin(panel);
        if icon != null { image(icon); }
        text(label, desc.text_desc);
        panel_end();
    }

    title_area :: proc(desc: Title_Area_Desc) -> Interact_Handle {
        exit_handle: Interact_Handle;
        has_bg := desc.style != .NONE;

        // Resolve tint before opening any panels so we read the parent modal's style
        auto_tint := resolve_parent_tint();

        spacer(flex(1), pixels(30));

        // Outer container: full width, fit height, horizontal padding insets the banner
        outer := layout_column();
        outer.width = flex(1);
        outer.height = fit();
        outer.cross_align = .CENTER;
        outer.padding = v4{0, 120, 0, 120};
        panel_begin(outer);

        // Background panel: fills outer's content area, centered text
        bg := layout_row();
        bg.width = flex(1);
        bg.height = fit();
        bg.padding = v4{8, 16, 8, 16};
        bg.main_align = .CENTER;
        bg.cross_align = .CENTER;
        if has_bg {
            bg.background = .BANNER_NORMAL;
            bg.show_background = true;
            if desc.tint.w > 0 {
                bg.tint = desc.tint;
            } else {
                bg.tint = auto_tint;
            }
        }
        panel_begin(bg);

        // Title text (centered via MAIN_CENTER on parent)
        text(desc.title, text_title());

        // Icon overlay: left edge of bg, full height, aspect-preserved
        if desc.icon != null {
            icon_panel := layout_column();
            icon_panel.width = fit();
            icon_panel.height = flex(1);
            icon_panel.cross_align = .CENTER;
            icon_panel.main_align = .CENTER;
            overlay_begin(.CENTER_LEFT, icon_panel, v2{0, 0}, .CENTER, .CENTER);
            image_fitted(desc.icon, image_desc(.CONTAIN));
            overlay_end();
        }

        panel_end(); // bg

        // Exit button overlay: top right of outer
        if desc.show_exit {
            exit_tex := get_asset(Texture_Asset, "$AO/ui/kit/Icons/misc_icons_2/exit_button_large.png");
            exit_overlay: Panel_Desc = {};
            exit_overlay.opacity = 1;
            exit_overlay.axis = .VERTICAL;
            exit_overlay.width = fit();
            exit_overlay.height = fit();
            exit_overlay.cross_align = .CENTER;
            exit_overlay.main_align = .CENTER;
            overlay_begin(.TOP_RIGHT, exit_overlay, v2{-8, 0});

            btn: Panel_Desc = {};
            btn.opacity = 1;
            btn.axis = .VERTICAL;
            btn.width = pixels(48);
            btn.height = pixels(48);
            btn.cross_align = .CENTER;
            btn.main_align = .CENTER;
            btn.show_background = false;
            exit_handle = panel_begin_interactive("title_area_exit", btn);
            image_fitted(exit_tex, image_desc(.CONTAIN));
            panel_end();

            overlay_end();
        }

        panel_end(); // outer

        spacer(flex(1), pixels(30));

        return exit_handle;
    }

    list_begin :: proc(id: string, viewport_desc: Panel_Desc, scroll_enabled: bool = true) {
        if scroll_enabled {
            scroll_area_begin(id, viewport_desc);
        } else {
            d := viewport_desc;
            d.clip_children = true;
            panel_begin(d);
        }
        col := layout_column();
        col.width = flex(1);
        col.height = fit();
        col.gap = 15;
        panel_begin(col);
    }

    list_end :: proc() {
        panel_end();
        panel_end();
    }


    rect_window :: proc() -> Rect {
        return UI.get_safe_screen_rect().center_rect().grow(440, 650, 440, 650);
    }

    rect_window_large :: proc() -> Rect {
        return UI.get_safe_screen_rect().inset(100, 200, 100, 200);
    }

    rect_window_small :: proc() -> Rect {
        return UI.get_safe_screen_rect().center_rect().grow(240, 325, 240, 325);
    }

    rect_sidebar_left :: proc() -> Rect {
        return UI.get_safe_screen_rect().left_rect().grow_right(300).inset(300, 0, 250, 0).offset(15, 0);
    }

    rect_sidebar_right :: proc() -> Rect {
        return UI.get_safe_screen_rect().right_rect().grow_left(300).inset(300, 0, 250, 0).offset(-15, 0);
    }

    rect_topbar :: proc() -> Rect {
        return UI.get_safe_screen_rect().top_rect().grow_bottom(150).inset(0, 400, 0, 400).offset(0, -15);
    }

    rect_hotbar :: proc() -> Rect {
        return UI.get_safe_screen_rect().bottom_rect().grow_top(150).inset(0, 500, 0, 500).offset(0, 15);
    }

    rect_stats :: proc() -> Rect {
        return UI.get_safe_screen_rect().bottom_left_rect().grow(450, 400, 0, 0).offset(15, 15);
    }

    rect_dialog :: proc() -> Rect {
        return UI.get_safe_screen_rect().top_rect().grow_bottom(275).inset(0, 800, 0, 800).offset(0, 165);
    }
}
