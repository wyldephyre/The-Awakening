import "core:ao"
import "core:dropped_items"
import "character"
import "outpost"
import "crafting"
import "combat"
import "enemies"
import "ui"

ao_before_scene_load :: proc() {
    register_resources();
}

ao_start :: proc() {
}

ao_update :: proc(dt: float) {
    update_enemy_spawner(dt);
    update_damage_numbers(dt);
}

ao_late_update :: proc(dt: float) {
    draw_damage_numbers();
}
